# Postgres
POSTGRES_USER=shepherd
POSTGRES_PASSWORD=shepherd
POSTGRES_DB=shepherd
DATABASE_URL=postgresql+psycopg://shepherd:shepherd@localhost:5432/shepherd

# AWS / S3 / Bedrock
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=shepherd-docs
IMAGE_CONFIDENCE_MIN=0.6
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=

# External LLMs
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Telegram bot (services/telegram-bot - aiogram long-polling, replaces n8n).
# OPENAI_API_KEY (Whisper STT) + GEMINI_API_KEY (doc-scan vision) are under External LLMs.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=ShepherdBot

# Internal service auth
INTERNAL_SERVICE_TOKEN=change-me

# Google Drive storage (Fleet API owns uploads: accident attachments + scanned docs).
# Service-account JSON key + the Shared Drive folder it can write to. Share the folder
# with the service-account email. GDRIVE_SA_KEY_PATH is the host path docker-compose
# mounts into fleet-api at GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gdrive-sa.json
GDRIVE_SA_KEY_PATH=./secrets/gdrive-sa.json
GDRIVE_FOLDER_ID=

# Provider selection (swappable abstractions)
EXTRACTOR_PROVIDER=bedrock
GUARDRAIL_PROVIDER=guardrails_ai

# Guardrails service (hub auth + backing LLM for rails)
GUARDRAILS_API_KEY=
GUARDRAILS_LLM=openai/gpt-4o-mini

# RAG service
ANTHROPIC_MODEL=claude-sonnet-4-6

# LangGraph agent (service URLs for inter-service calls)
FLEET_API_URL=http://fleet-api:8000
RAG_URL=http://rag:8000

# Ollama assistant (general fleet helper, DB-blind)
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=60

# WebUI admin console (Next.js)
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@fleetops.io
ADMIN_PASSWORD=
NEXT_PUBLIC_FLEET_API_URL=http://fleet-api:8000
NEXT_PUBLIC_AGENT_URL=http://langgraph-agent:8000
NEXT_PUBLIC_RAG_URL=http://rag:8000
NEXT_PUBLIC_GATEWAY_URL=http://channel-gateway:8000
NEXT_PUBLIC_ASSISTANT_URL=http://ollama-assistant:8000
