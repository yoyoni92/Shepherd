# Postgres
POSTGRES_USER=shepherd
POSTGRES_PASSWORD=shepherd
POSTGRES_DB=shepherd
DATABASE_URL=postgresql+psycopg://shepherd:shepherd@localhost:5432/shepherd

# External LLMs
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Telegram bot (services/telegram-bot - aiogram long-polling).
# OPENAI_API_KEY (Whisper STT) + GEMINI_API_KEY (doc-scan vision) are under External LLMs.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=ShepherdBot

# Internal service auth
INTERNAL_SERVICE_TOKEN=change-me

# Google Drive storage (Fleet API owns uploads: accident attachments + scanned docs).
# Service-account JSON key + the Shared Drive folder it can write to. Share the folder
# with the service-account email. GDRIVE_SA_KEY_PATH is the host path docker-compose
# mounts into fleet-api at GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gdrive-sa.json
GDRIVE_SA_KEY_PATH=./secrets/gdrive-sa.json
GDRIVE_FOLDER_ID=

# Inter-service URL (the bot and webui call Fleet API)
FLEET_API_URL=http://fleet-api:8000

# WebUI admin console (Next.js)
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@fleetops.io
ADMIN_PASSWORD=
NEXT_PUBLIC_FLEET_API_URL=http://fleet-api:8000
