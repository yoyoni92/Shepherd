NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000
ADMIN_EMAIL=admin@fleetops.io
ADMIN_PASSWORD=

# Fleet API is reached via the server-only proxy (app/api/fleet). These two are server-side
# secrets and must NOT be NEXT_PUBLIC_ (the internal token would leak to the browser otherwise).
FLEET_API_URL=http://fleet-api:8000
INTERNAL_SERVICE_TOKEN=change-me-internal-token

# Agent / RAG / gateway / assistant are reached via the server-only generic proxy
# (app/api/proxy/[svc]). Server-side only — private hostnames must never reach the browser.
AGENT_URL=http://langgraph-agent:8000
RAG_URL=http://rag:8000
GATEWAY_URL=http://channel-gateway:8000
ASSISTANT_URL=http://ollama-assistant:8000

# Phone the admin uploads on behalf of (channel-gateway routes ingestion by phone).
NEXT_PUBLIC_ADMIN_PHONE=admin
