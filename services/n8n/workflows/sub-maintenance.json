    {
      "id": "a1b2c3d4-1057-1057-1057-000000001057",
      "name": "Code: MaintLog Validate KM",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        300,
        1000
      ],
      "parameters": {
        "jsCode": "const ctx = $('On Parent Call').first().json;\nconst state = ctx.sessionState||{};\nconst raw = (ctx.text||'').trim();\nconst km = parseInt(raw,10);\nconst valid = /^\\d+$/.test(raw) && km>=0;\nconst today = new Date().toISOString().slice(0,10);\nreturn [{ json: { chatId: ctx.chatId, valid, km, vehicleId: state.vehicleId, maintType: state.maintType, serviceDate: today, errorMsg:'⚠️ ק\"מ לא תקין. הזן/י מספר.' } }];"
      }
    },
