    {
      "id": "a1b2c3d4-1043-1043-1043-000000001043",
      "name": "Code: Format Overdue",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        200
      ],
      "parameters": {
        "jsCode": "const ctx = $('On Parent Call').first().json;\nconst all = $input.all().map(i=>i.json);\nconst rows = all.filter(r=>r.licensing_plate && r.current_km!=null && r.next_maintenance_km!=null && r.current_km>=r.next_maintenance_km)\n  .sort((a,b)=>(b.current_km-b.next_maintenance_km)-(a.current_km-a.next_maintenance_km));\nlet text;\nif (!rows.length) text='✅ אין תחזוקות באיחור.';\nelse { text='📋 תחזוקות באיחור\\n━━━━━━━━━━━━━━━━\\n';\n  for (const r of rows) text+=`\\n🚗 ${r.licensing_plate} (${r.vendor||''} ${r.model||''})\\n   ק\"מ: ${r.current_km} / יעד: ${r.next_maintenance_km}\\n   סוג: ${r.next_maintenance_type||'-'}\\n`;\n}\nreturn [{ json: { chatId: ctx.chatId, text } }];"
      }
    },
