    {
      "id": "a1b2c3d4-0200-0200-0200-000000000200",
      "name": "Code: Prepare Broadcast Send",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        300,
        400
      ],
      "parameters": {
        "jsCode": "const ctx = $('On Parent Call').first().json;\nconst state = ctx.sessionState || {};\nconst broadcastMsg = state.message || '';\nconst drivers = state.drivers || [];\nreturn drivers.filter(d => d.telegram_chat_id).map(d => ({ json: { chatId: ctx.chatId, recipientChatId: d.telegram_chat_id, broadcastMsg } }));"
      }
