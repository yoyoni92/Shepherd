      "id": "a1b2c3d4-0191-0191-0191-000000000191",
      "name": "Code: Prepare Broadcast Confirm",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        200
      ],
      "parameters": {
        "jsCode": "const ctx = $('On Parent Call').first().json;\nconst driversResult = $input.first().json;\nconst drivers = Array.isArray(driversResult) ? driversResult : (driversResult.items || []);\nconst withChat = drivers.filter(d => d.telegram_chat_id);\nconst count = withChat.length;\nconst broadcastMsg = ctx.text;\nreturn [{ json: { ...ctx, broadcastMsg, driverCount: count, drivers: withChat } }];"
      }
