    {
      "id": "a1b2c3d4-6002-6002-6002-000000006002",
      "name": "Code: Format Clock In",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        0
      ],
      "parameters": {
        "jsCode": "const ctx = $('On Parent Call').first().json;\nconst r = $input.first().json || {};\nlet text;\nif (r.result==='blocked') text=`⛔ דיווח נוכחות אפשרי רק בין ${r.window_start} ל-${r.window_end}.`;\nelse if (r.result==='already_in') text=`כבר נרשמת כניסה היום בשעה ${r.time}.`;\nelse if (r.result==='ok') text=`✅ כניסה נרשמה בהצלחה בשעה ${r.time}.`;\nelse text='⚠️ אירעה שגיאה ברישום הכניסה.';\nreturn [{ json: { chatId: ctx.chatId, text } }];"
      }
    },
