    {
      "id": "a1b2c3d4-6005-6005-6005-000000006005",
      "name": "Code: Format Clock Out",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        540,
        200
      ],
      "parameters": {
        "jsCode": "const ctx = $('On Parent Call').first().json;\nconst r = $input.first().json || {};\nlet text;\nif (r.result==='blocked') text=`⛔ דיווח נוכחות אפשרי רק בין ${r.window_start} ל-${r.window_end}.`;\nelse if (r.result==='no_open') text='לא נמצאה כניסה פתוחה להיום.';\nelse if (r.result==='ok') text=`✅ יציאה נרשמה. סה\"כ: ${r.hours} שעות.`;\nelse text='⚠️ אירעה שגיאה ברישום היציאה.';\nreturn [{ json: { chatId: ctx.chatId, text } }];"
      }
    },
